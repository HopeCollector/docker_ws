{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "source /opt/ros/humble/setup.bash && colcon build --symlink-install --parallel-workers 2 --base-paths src --event-handlers desktop_notification- --cmake-args -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "rviz",
      "type": "shell",
      "command": "source /opt/ros/humble/setup.bash && rviz2 -d install/roaf3d/share/roaf3d/launch/rviz.rviz",
      "problemMatcher": []
    },
    {
      "label": "test ouster",
      "type": "process",
      "command": "/home/lawskiy/roaf3d_ws/scripts/test/ouster.sh",
      "problemMatcher": [],
      "options": {"cwd": "${workspaceFolder}"}
    }
  ]
}